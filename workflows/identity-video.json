{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive_prompt}}",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{reference_image}}"
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{width}}",
      "height": "{{height}}",
      "batch_size": "{{frames}}"
    }
  },

  "10": {
    "class_type": "IPAdapterModelLoader",
    "inputs": {
      "ipadapter_file": "ip-adapter-plus-face_sdxl_vit-h.safetensors"
    }
  },
  "11": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors"
    }
  },
  "12": {
    "class_type": "IPAdapterApply",
    "inputs": {
      "ipadapter": ["10", 0],
      "clip_vision": ["11", 0],
      "image": ["4", 0],
      "model": ["1", 0],
      "weight": 0.85,
      "noise": 0.01,
      "weight_type": "linear",
      "start_at": 0.0,
      "end_at": 1.0
    }
  },

  "20": {
    "_phase_min": 2,
    "class_type": "PulidModelLoader",
    "inputs": {
      "pulid_file": "ip-adapter_pulid_sdxl_fp16.safetensors"
    }
  },
  "21": {
    "_phase_min": 2,
    "class_type": "PulidInsightFaceLoader",
    "inputs": {
      "provider": "CPU"
    }
  },
  "22": {
    "_phase_min": 2,
    "class_type": "ApplyPulid",
    "inputs": {
      "model": ["12", 0],
      "pulid": ["20", 0],
      "insightface": ["21", 0],
      "image": ["4", 0],
      "weight": 0.75,
      "start_at": 0.0,
      "end_at": 1.0
    }
  },

  "30": {
    "_phase_min": 2,
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "control-lora-openposeXL2-rank256.safetensors"
    }
  },
  "31": {
    "_phase_min": 2,
    "class_type": "DWPreprocessor",
    "inputs": {
      "image": ["4", 0],
      "detect_hand": "enable",
      "detect_body": "enable",
      "detect_face": "enable",
      "resolution": 512
    }
  },
  "32": {
    "_phase_min": 2,
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["2", 0],
      "negative": ["3", 0],
      "control_net": ["30", 0],
      "image": ["31", 0],
      "strength": 0.6,
      "start_percent": 0.0,
      "end_percent": 0.8
    }
  },

  "40": {
    "class_type": "ADE_AnimateDiffLoaderWithContext",
    "inputs": {
      "model_name": "mm_sdxl_v10_beta.ckpt",
      "beta_schedule": "sqrt_linear (AnimateDiff)",
      "context_options": ["41", 0]
    }
  },
  "41": {
    "class_type": "ADE_StandardStaticContextOptions",
    "inputs": {
      "context_length": 16,
      "context_stride": 1,
      "context_overlap": 4,
      "context_schedule": "uniform",
      "closed_loop": false
    }
  },
  "42": {
    "class_type": "ADE_ApplyAnimateDiffModel",
    "inputs": {
      "motion_model": ["40", 0],
      "model": "{{model_source}}"
    }
  },

  "50": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["42", 0],
      "positive": "{{positive_source}}",
      "negative": "{{negative_source}}",
      "latent_image": ["5", 0],
      "seed": "{{seed}}",
      "steps": 20,
      "cfg": 7.5,
      "sampler_name": "euler_ancestral",
      "scheduler": "normal",
      "denoise": 1.0
    }
  },
  "51": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["50", 0],
      "vae": ["1", 2]
    }
  },
  "52": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["51", 0],
      "frame_rate": "{{fps}}",
      "loop_count": 0,
      "filename_prefix": "1000ds_output",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  }
}
